<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const tiltCards = Array.from(document.querySelectorAll('.js-tilt-card'));

  tiltCards.forEach((card) => {
    const element = card instanceof HTMLElement ? card : null;
    if (!element || prefersReducedMotion) return;

    const inner = element.firstElementChild instanceof HTMLElement ? element.firstElementChild : element;

    element.addEventListener('pointermove', (event) => {
      const bounds = element.getBoundingClientRect();
      const x = event.clientX - bounds.left;
      const y = event.clientY - bounds.top;
      const rotateY = gsap.utils.mapRange(0, bounds.width, -8, 8, x);
      const rotateX = gsap.utils.mapRange(0, bounds.height, 8, -8, y);

      gsap.to(inner, {
        rotateX,
        rotateY,
        transformPerspective: 900,
        transformOrigin: 'center',
        duration: 0.45,
        ease: 'power3.out',
      });
    });

    element.addEventListener('pointerleave', () => {
      gsap.to(inner, {
        rotateX: 0,
        rotateY: 0,
        duration: 0.6,
        ease: 'power3.out',
      });
    });
  });

  const reveals = gsap.utils.toArray('.reveal');

  if (!prefersReducedMotion) {
    reveals.forEach((element, index) => {
      gsap.fromTo(
        element,
        { autoAlpha: 0, y: 42, scale: 0.98 },
        {
          autoAlpha: 1,
          y: 0,
          scale: 1,
          duration: 1,
          delay: index < 4 ? index * 0.08 : 0,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: element,
            start: 'top 84%',
            once: true,
          },
        },
      );
    });

    gsap.utils.toArray('.js-parallax').forEach((element) => {
      gsap.fromTo(
        element,
        { yPercent: -4, scale: 1.02 },
        {
          yPercent: 4,
          scale: 1.08,
          ease: 'none',
          scrollTrigger: {
            trigger: element,
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        },
      );
    });

    gsap.utils.toArray('.js-skill-bar').forEach((bar) => {
      gsap.fromTo(
        bar,
        { scaleX: 0, transformOrigin: 'left center' },
        {
          scaleX: 1,
          duration: 1.1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: bar,
            start: 'top 88%',
            once: true,
          },
        },
      );
    });

    gsap.fromTo(
      '.js-tech-pill',
      { y: 10, autoAlpha: 0 },
      {
        y: 0,
        autoAlpha: 1,
        duration: 0.6,
        stagger: 0.06,
        ease: 'power3.out',
        delay: 0.35,
      },
    );
  } else {
    reveals.forEach((element) => {
      if (element instanceof HTMLElement) {
        element.style.opacity = '1';
        element.style.transform = 'none';
      }
    });
  }
</script>
